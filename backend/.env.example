# PostgreSQL (Railway expone DATABASE_URL automáticamente)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marisa?schema=public"

# Servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="cambiar-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="otro-secreto-distinto-para-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (origen del frontend; en prod la URL de Vercel)
CORS_ORIGIN="http://localhost:4200"

// Sistema de Gestión de Producción y Nómina
// Esquema completo traducido de docs/02_ESQUEMA_BD.md a PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── ENUMS ─────────────────────────────

enum Rol {
  ADMIN
  GERENTE
  OPERARIO
  RRHH
  CONTADOR
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
  PERDIDA
}

enum EstadoOrden {
  PLANIFICADA
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

enum TipoComprobante {
  REMITO
  FACTURA
  NOTA_CREDITO
}

enum EstadoEmpleado {
  ACTIVO
  INACTIVO
  LICENCIA
  EGRESADO
}

enum TipoAporte {
  APORTE_PATRONAL
  DESCUENTO_NOMINA
  ANTIGUEDAD
  BONO
}

enum EstadoNomina {
  BORRADOR
  PROCESADA
  PAGADA
  CANCELADA
}

enum TipoDia {
  NORMAL
  FERIADO
  LICENCIA
  FALTA
  AUSENCIA_INJUSTIFICADA
}

// ──────────────────────── USUARIOS Y SEGURIDAD ────────────────────────

model Usuario {
  id              BigInt   @id @default(autoincrement())
  username        String   @unique @db.VarChar(50)
  email           String   @unique @db.VarChar(100)
  contrasenaHash  String   @map("contrasena_hash") @db.VarChar(255)
  rol             Rol
  activo          Boolean  @default(true)
  ultimoLogin     DateTime? @map("ultimo_login")
  fechaCreacion   DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  movimientos       MovimientoInsumo[]   @relation("MovimientoCreador")
  auditoriaLogs     AuditoriaLog[]
  recetas           Receta[]
  ordenes           OrdenProduccion[]
  ventas            Venta[]
  estructurasSalariales EstructuraSalarial[]
  nominas           NominaMensual[]

  @@index([rol])
  @@index([activo])
  @@map("usuarios")
}

model Permiso {
  id          Int    @id @default(autoincrement())
  codigo      String @unique @db.VarChar(100)
  descripcion String? @db.VarChar(200)
  modulo      String? @db.VarChar(50)
  accion      String? @db.VarChar(50)

  roles RolPermiso[]

  @@map("permisos")
}

model RolPermiso {
  id        BigInt @id @default(autoincrement())
  rol       Rol
  permisoId Int    @map("permiso_id")

  permiso Permiso @relation(fields: [permisoId], references: [id])

  @@unique([rol, permisoId])
  @@map("rol_permisos")
}

// ──────────────────── MATERIA PRIMA E INSUMOS ────────────────────

model Insumo {
  id                    BigInt   @id @default(autoincrement())
  codigo                String   @unique @db.VarChar(50)
  nombre                String   @db.VarChar(150)
  descripcion           String?
  categoria             String   @db.VarChar(100)
  unidadMedida          String   @map("unidad_medida") @db.VarChar(20)
  precioUnitario        Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  costoActual           Decimal  @map("costo_actual") @db.Decimal(10, 2)
  stockMinimo           Decimal  @default(0) @map("stock_minimo") @db.Decimal(10, 2)
  stockCritico          Decimal  @default(0) @map("stock_critico") @db.Decimal(10, 2)
  diasVencimientoAlerta Int      @default(30) @map("dias_vencimiento_alerta")
  activo                Boolean  @default(true)
  observaciones         String?
  fechaCreacion         DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion    DateTime @updatedAt @map("fecha_actualizacion")

  movimientos     MovimientoInsumo[]
  stock           StockActual?
  recetaDetalles  RecetaDetalle[]
  consumos        ConsumoInsumo[]
  historialPrecios HistorialPrecio[]

  @@index([categoria])
  @@index([activo])
  @@map("insumos")
}

model MovimientoInsumo {
  id                 BigInt         @id @default(autoincrement())
  insumoId           BigInt         @map("insumo_id")
  tipoMovimiento     TipoMovimiento @map("tipo_movimiento")
  cantidad           Decimal        @db.Decimal(10, 3)
  cantidadAnterior   Decimal?       @map("cantidad_anterior") @db.Decimal(10, 3)
  cantidadPosterior  Decimal?       @map("cantidad_posterior") @db.Decimal(10, 3)
  precioUnitario     Decimal?       @map("precio_unitario") @db.Decimal(10, 2)
  valorTotal         Decimal?       @map("valor_total") @db.Decimal(12, 2)
  fechaMovimiento    DateTime       @map("fecha_movimiento")
  motivo             String?        @db.VarChar(200)
  referenciaId       BigInt?        @map("referencia_id")
  referenciaTipo     String?        @map("referencia_tipo") @db.VarChar(50)
  responsableId      BigInt?        @map("responsable_id")
  numeroLote         String?        @map("numero_lote") @db.VarChar(100)
  fechaVencimiento   DateTime?      @map("fecha_vencimiento") @db.Date
  observaciones      String?
  creadoPorId        BigInt         @map("creado_por_id")
  fechaCreacion      DateTime       @default(now()) @map("fecha_creacion")

  insumo      Insumo    @relation(fields: [insumoId], references: [id])
  responsable Empleado? @relation(fields: [responsableId], references: [id])
  creadoPor   Usuario   @relation("MovimientoCreador", fields: [creadoPorId], references: [id])
  consumos    ConsumoInsumo[]

  @@index([insumoId, fechaMovimiento])
  @@index([tipoMovimiento])
  @@index([referenciaId, referenciaTipo])
  @@map("movimientos_insumos")
}

model StockActual {
  id               BigInt   @id @default(autoincrement())
  insumoId         BigInt   @unique @map("insumo_id")
  cantidadStock    Decimal  @default(0) @map("cantidad_stock") @db.Decimal(10, 3)
  valorStock       Decimal  @default(0) @map("valor_stock") @db.Decimal(12, 2)
  ultimoMovimiento DateTime? @map("ultimo_movimiento")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@map("stock_actual")
}

// ──────────────────────────── PRODUCTOS ────────────────────────────

model Producto {
  id                    BigInt   @id @default(autoincrement())
  codigo                String   @unique @db.VarChar(50)
  nombre                String   @db.VarChar(150)
  descripcion           String?
  categoria             String   @db.VarChar(100)
  pesoGramos            Int?     @map("peso_gramos")
  activo                Boolean  @default(true)
  costoPromedio         Decimal? @map("costo_promedio") @db.Decimal(10, 2)
  precioVenta           Decimal? @map("precio_venta") @db.Decimal(10, 2)
  margenBrutoPorcentaje Decimal? @map("margen_bruto_porcentaje") @db.Decimal(5, 2)
  observaciones         String?
  fechaCreacion         DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion    DateTime @updatedAt @map("fecha_actualizacion")

  recetas       Receta[]
  ordenes       OrdenProduccion[]
  ventaDetalles VentaDetalle[]

  @@index([categoria])
  @@index([activo])
  @@map("productos")
}

model Receta {
  id                  BigInt   @id @default(autoincrement())
  codigo              String   @unique @db.VarChar(50)
  productoId          BigInt   @map("producto_id")
  version             Int      @default(1)
  rendimientoEsperado Decimal  @map("rendimiento_esperado") @db.Decimal(10, 3)
  unidadRendimiento   String   @map("unidad_rendimiento") @db.VarChar(20)
  costoTotalEsperado  Decimal? @map("costo_total_esperado") @db.Decimal(10, 2)
  activa              Boolean  @default(true)
  fechaInicioValidez  DateTime? @map("fecha_inicio_validez") @db.Date
  fechaFinValidez     DateTime? @map("fecha_fin_validez") @db.Date
  creadoPorId         BigInt?  @map("creado_por_id")
  observaciones       String?
  fechaCreacion       DateTime @default(now()) @map("fecha_creacion")

  producto  Producto        @relation(fields: [productoId], references: [id])
  creadoPor Usuario?        @relation(fields: [creadoPorId], references: [id])
  detalles  RecetaDetalle[]
  ordenes   OrdenProduccion[]

  @@index([productoId])
  @@index([activa])
  @@map("recetas")
}

model RecetaDetalle {
  id                BigInt   @id @default(autoincrement())
  recetaId          BigInt   @map("receta_id")
  insumoId          BigInt   @map("insumo_id")
  cantidadRequerida Decimal  @map("cantidad_requerida") @db.Decimal(10, 3)
  unidadMedida      String   @map("unidad_medida") @db.VarChar(20)
  porcentajeMerma   Decimal  @default(0) @map("porcentaje_merma") @db.Decimal(5, 2)
  cantidadConMerma  Decimal? @map("cantidad_con_merma") @db.Decimal(10, 3)
  costoUnitario     Decimal? @map("costo_unitario") @db.Decimal(10, 2)
  costoTotal        Decimal? @map("costo_total") @db.Decimal(10, 2)
  orden             Int?
  observaciones     String?

  receta Receta @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([recetaId])
  @@map("receta_detalles")
}

// ──────────────────────────── PRODUCCIÓN ────────────────────────────

model OrdenProduccion {
  id                  BigInt      @id @default(autoincrement())
  numeroOrden         String      @unique @map("numero_orden") @db.VarChar(50)
  productoId          BigInt      @map("producto_id")
  recetaId            BigInt      @map("receta_id")
  cantidadSolicitada  Decimal     @map("cantidad_solicitada") @db.Decimal(10, 3)
  cantidadProducida   Decimal?    @map("cantidad_producida") @db.Decimal(10, 3)
  cantidadDefectuosa  Decimal     @default(0) @map("cantidad_defectuosa") @db.Decimal(10, 3)
  fechaProduccion     DateTime    @map("fecha_produccion") @db.Date
  horaInicio          DateTime?   @map("hora_inicio") @db.Time
  horaFin             DateTime?   @map("hora_fin") @db.Time
  estado              EstadoOrden @default(PLANIFICADA)
  responsableId       BigInt?     @map("responsable_id")
  observaciones       String?
  creadoPorId         BigInt      @map("creado_por_id")
  fechaCreacion       DateTime    @default(now()) @map("fecha_creacion")

  producto    Producto  @relation(fields: [productoId], references: [id])
  receta      Receta    @relation(fields: [recetaId], references: [id])
  responsable Empleado? @relation(fields: [responsableId], references: [id])
  creadoPor   Usuario   @relation(fields: [creadoPorId], references: [id])
  consumos    ConsumoInsumo[]

  @@index([fechaProduccion])
  @@index([estado])
  @@index([responsableId])
  @@map("ordenes_produccion")
}

model ConsumoInsumo {
  id                   BigInt   @id @default(autoincrement())
  ordenProduccionId    BigInt   @map("orden_produccion_id")
  insumoId             BigInt   @map("insumo_id")
  cantidadPrevista     Decimal? @map("cantidad_prevista") @db.Decimal(10, 3)
  cantidadUtilizada    Decimal  @map("cantidad_utilizada") @db.Decimal(10, 3)
  diferencia           Decimal? @db.Decimal(10, 3)
  porcentajeDiferencia Decimal? @map("porcentaje_diferencia") @db.Decimal(5, 2)
  precioUnitario       Decimal? @map("precio_unitario") @db.Decimal(10, 2)
  costoTotal           Decimal? @map("costo_total") @db.Decimal(10, 2)
  movimientoInsumoId   BigInt?  @map("movimiento_insumo_id")
  fechaRegistro        DateTime @default(now()) @map("fecha_registro")

  orden      OrdenProduccion   @relation(fields: [ordenProduccionId], references: [id])
  insumo     Insumo            @relation(fields: [insumoId], references: [id])
  movimiento MovimientoInsumo? @relation(fields: [movimientoInsumoId], references: [id])

  @@index([ordenProduccionId])
  @@map("consumo_insumos")
}

model ResumenProduccionDiaria {
  id                   BigInt   @id @default(autoincrement())
  fechaProduccion      DateTime @unique @map("fecha_produccion") @db.Date
  cantidadOrdenes      Int?     @map("cantidad_ordenes")
  costoTotalInsumos    Decimal? @map("costo_total_insumos") @db.Decimal(12, 2)
  mermaTotalPorcentaje Decimal? @map("merma_total_porcentaje") @db.Decimal(5, 2)
  observaciones        String?
  generadoPorId        BigInt?  @map("generado_por_id")
  fechaGeneracion      DateTime @default(now()) @map("fecha_generacion")

  @@index([fechaProduccion])
  @@map("resumen_produccion_diaria")
}

// ──────────────────────────── VENTAS ────────────────────────────

model Venta {
  id                  BigInt          @id @default(autoincrement())
  numeroComprobante   String          @unique @map("numero_comprobante") @db.VarChar(50)
  tipoComprobante     TipoComprobante @default(REMITO) @map("tipo_comprobante")
  clienteNombre       String?         @map("cliente_nombre") @db.VarChar(200)
  clienteCuit         String?         @map("cliente_cuit") @db.VarChar(20)
  fechaVenta          DateTime        @map("fecha_venta")
  totalBruto          Decimal         @map("total_bruto") @db.Decimal(12, 2)
  descuentoPorcentaje Decimal         @default(0) @map("descuento_porcentaje") @db.Decimal(5, 2)
  descuentoMonto      Decimal         @default(0) @map("descuento_monto") @db.Decimal(12, 2)
  totalNeto           Decimal         @map("total_neto") @db.Decimal(12, 2)
  medioPago           String?         @map("medio_pago") @db.VarChar(50)
  registradoPorId     BigInt          @map("registrado_por_id")
  observaciones       String?
  fechaCreacion       DateTime        @default(now()) @map("fecha_creacion")
  anulada             Boolean         @default(false)
  fechaAnulacion      DateTime?       @map("fecha_anulacion")
  motivoAnulacion     String?         @map("motivo_anulacion") @db.VarChar(200)

  registradoPor Usuario        @relation(fields: [registradoPorId], references: [id])
  detalles      VentaDetalle[]

  @@index([fechaVenta])
  @@index([clienteNombre])
  @@index([anulada])
  @@map("ventas")
}

model VentaDetalle {
  id                 BigInt   @id @default(autoincrement())
  ventaId            BigInt   @map("venta_id")
  productoId         BigInt   @map("producto_id")
  cantidad           Decimal  @db.Decimal(10, 3)
  precioUnitario     Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  subtotal           Decimal  @db.Decimal(12, 2)
  costoUnitario      Decimal? @map("costo_unitario") @db.Decimal(10, 2)
  gananciaUnitaria   Decimal? @map("ganancia_unitaria") @db.Decimal(10, 2)
  porcentajeGanancia Decimal? @map("porcentaje_ganancia") @db.Decimal(5, 2)
  observaciones      String?

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([ventaId])
  @@map("venta_detalles")
}

// ──────────────────────── EMPLEADOS Y NÓMINA ────────────────────────

model Empleado {
  id                BigInt         @id @default(autoincrement())
  dni               String         @unique @db.VarChar(20)
  nombre            String         @db.VarChar(100)
  apellido          String         @db.VarChar(100)
  email             String?        @db.VarChar(100)
  telefono          String?        @db.VarChar(20)
  direccion         String?
  localidad         String?        @db.VarChar(100)
  fechaNacimiento   DateTime?      @map("fecha_nacimiento") @db.Date
  puesto            String         @db.VarChar(100)
  departamento      String?        @db.VarChar(100)
  fechaIngreso      DateTime       @map("fecha_ingreso") @db.Date
  fechaEgreso       DateTime?      @map("fecha_egreso") @db.Date
  estado            EstadoEmpleado @default(ACTIVO)
  cuitEmpleado      String?        @map("cuit_empleado") @db.VarChar(20)
  numeroAfiliacion  String?        @map("numero_afiliacion") @db.VarChar(50)
  activo            Boolean        @default(true)
  observaciones     String?
  fechaCreacion     DateTime       @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime      @updatedAt @map("fecha_actualizacion")

  estructuras   EstructuraSalarial[]
  recibos       ReciboSueldo[]
  asistencias   Asistencia[]
  historialSalarial HistorialEstructuraSalarial[]
  movimientos   MovimientoInsumo[]
  ordenes       OrdenProduccion[]

  @@index([dni])
  @@index([estado])
  @@index([fechaIngreso])
  @@map("empleados")
}

model EstructuraSalarial {
  id                 BigInt   @id @default(autoincrement())
  empleadoId         BigInt   @map("empleado_id")
  sueldoBasico       Decimal  @map("sueldo_basico") @db.Decimal(10, 2)
  tarifaHoraria      Decimal? @map("tarifa_horaria") @db.Decimal(10, 2)
  bonoFijo           Decimal  @default(0) @map("bono_fijo") @db.Decimal(10, 2)
  comisionPorcentaje Decimal  @default(0) @map("comision_porcentaje") @db.Decimal(5, 2)
  anticipoDescuento  Decimal  @default(0) @map("anticipo_descuento") @db.Decimal(10, 2)
  fechaInicio        DateTime @map("fecha_inicio") @db.Date
  fechaFin           DateTime? @map("fecha_fin") @db.Date
  vigente            Boolean  @default(true)
  cambioAnteriorId   BigInt?  @map("cambio_anterior_id")
  creadoPorId        BigInt?  @map("creado_por_id")
  observaciones      String?
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")

  empleado       Empleado            @relation(fields: [empleadoId], references: [id])
  cambioAnterior EstructuraSalarial? @relation("CambioEstructura", fields: [cambioAnteriorId], references: [id])
  siguientes     EstructuraSalarial[] @relation("CambioEstructura")
  creadoPor      Usuario?            @relation(fields: [creadoPorId], references: [id])

  @@index([empleadoId])
  @@index([vigente])
  @@map("estructura_salarial")
}

model ConfiguracionAporte {
  id            BigInt     @id @default(autoincrement())
  nombre        String     @db.VarChar(150)
  tipo          TipoAporte
  porcentaje    Decimal    @db.Decimal(5, 2)
  descripcion   String?
  fechaInicio   DateTime   @map("fecha_inicio") @db.Date
  fechaFin      DateTime?  @map("fecha_fin") @db.Date
  activo        Boolean    @default(true)
  creadoPorId   BigInt?    @map("creado_por_id")
  fechaCreacion DateTime   @default(now()) @map("fecha_creacion")

  @@index([tipo])
  @@index([activo])
  @@map("configuracion_aportes")
}

model EscalaAntiguedad {
  id                  BigInt   @id @default(autoincrement())
  anosDesde           Int      @map("anos_desde")
  anosHasta           Int?     @map("anos_hasta")
  porcentajeAdicional Decimal  @map("porcentaje_adicional") @db.Decimal(5, 2)
  descripcion         String?  @db.VarChar(200)
  fechaVigencia       DateTime? @map("fecha_vigencia") @db.Date
  activo              Boolean  @default(true)

  @@index([anosDesde, anosHasta])
  @@map("escala_antiguedad")
}

model NominaMensual {
  id                 BigInt       @id @default(autoincrement())
  numeroNomina       String       @unique @map("numero_nomina") @db.VarChar(50)
  periodoMes         Int          @map("periodo_mes")
  periodoAnio        Int          @map("periodo_anio")
  fechaProcesamiento DateTime?    @map("fecha_procesamiento") @db.Date
  estado             EstadoNomina @default(BORRADOR)
  procesadoPorId     BigInt?      @map("procesado_por_id")
  observaciones      String?
  fechaCreacion      DateTime     @default(now()) @map("fecha_creacion")

  procesadoPor Usuario?       @relation(fields: [procesadoPorId], references: [id])
  recibos      ReciboSueldo[]

  @@index([periodoAnio, periodoMes])
  @@index([estado])
  @@map("nomina_mensual")
}

model ReciboSueldo {
  id              BigInt   @id @default(autoincrement())
  numeroRecibo    String   @unique @map("numero_recibo") @db.VarChar(50)
  nominaId        BigInt   @map("nomina_id")
  empleadoId      BigInt   @map("empleado_id")
  periodoMes      Int      @map("periodo_mes")
  periodoAnio     Int      @map("periodo_anio")

  sueldoBasico    Decimal? @map("sueldo_basico") @db.Decimal(10, 2)
  bonoFijo        Decimal? @map("bono_fijo") @db.Decimal(10, 2)
  antiguedadMonto Decimal? @map("antiguedad_monto") @db.Decimal(10, 2)
  comisiones      Decimal? @db.Decimal(10, 2)
  horasExtras     Decimal? @map("horas_extras") @db.Decimal(10, 2)
  otrosHaberes    Decimal? @map("otros_haberes") @db.Decimal(10, 2)
  totalHaberes    Decimal? @map("total_haberes") @db.Decimal(12, 2)

  aporteSindicato Decimal? @map("aporte_sindicato") @db.Decimal(10, 2)
  descuentoOtros  Decimal? @map("descuento_otros") @db.Decimal(10, 2)
  totalDescuentos Decimal? @map("total_descuentos") @db.Decimal(12, 2)

  salarioBruto    Decimal? @map("salario_bruto") @db.Decimal(12, 2)
  aportePatronal  Decimal? @map("aporte_patronal") @db.Decimal(12, 2)
  netoAPagar      Decimal? @map("neto_a_pagar") @db.Decimal(12, 2)

  fechaCreacion   DateTime @default(now()) @map("fecha_creacion")

  nomina   NominaMensual @relation(fields: [nominaId], references: [id])
  empleado Empleado      @relation(fields: [empleadoId], references: [id])

  @@index([empleadoId])
  @@index([periodoAnio, periodoMes])
  @@map("recibo_sueldo")
}

model Asistencia {
  id               BigInt   @id @default(autoincrement())
  empleadoId       BigInt   @map("empleado_id")
  fecha            DateTime @db.Date
  horaEntrada      DateTime? @map("hora_entrada") @db.Time
  horaSalida       DateTime? @map("hora_salida") @db.Time
  horasTrabajadas  Decimal? @map("horas_trabajadas") @db.Decimal(5, 2)
  tipoDia          TipoDia  @default(NORMAL) @map("tipo_dia")
  observaciones    String?
  registradoPorId  BigInt?  @map("registrado_por_id")
  fechaCreacion    DateTime @default(now()) @map("fecha_creacion")

  empleado Empleado @relation(fields: [empleadoId], references: [id])

  @@unique([empleadoId, fecha])
  @@index([empleadoId, fecha])
  @@map("asistencia")
}

// ──────────────────────────── AUDITORÍA ────────────────────────────

model AuditoriaLog {
  id                BigInt   @id @default(autoincrement())
  usuarioId         BigInt?  @map("usuario_id")
  nombreUsuario     String?  @map("nombre_usuario") @db.VarChar(50)
  accion            String   @db.VarChar(100)
  modulo            String   @db.VarChar(50)
  tablaAfectada     String?  @map("tabla_afectada") @db.VarChar(100)
  registroId        BigInt?  @map("registro_id")
  valoresAnteriores Json?    @map("valores_anteriores")
  valoresNuevos     Json?    @map("valores_nuevos")
  ipOrigen          String?  @map("ip_origen") @db.VarChar(45)
  userAgent         String?  @map("user_agent")
  fechaAccion       DateTime @default(now()) @map("fecha_accion")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, fechaAccion])
  @@index([tablaAfectada])
  @@index([accion])
  @@map("auditoria_logs")
}

model HistorialPrecio {
  id             BigInt   @id @default(autoincrement())
  insumoId       BigInt   @map("insumo_id")
  precioAnterior Decimal? @map("precio_anterior") @db.Decimal(10, 2)
  precioNuevo    Decimal  @map("precio_nuevo") @db.Decimal(10, 2)
  fechaCambio    DateTime @map("fecha_cambio")
  cambioPorId    BigInt?  @map("cambio_por_id")
  razonCambio    String?  @map("razon_cambio") @db.VarChar(200)

  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([insumoId, fechaCambio])
  @@map("historial_precios")
}

model HistorialEstructuraSalarial {
  id                     BigInt   @id @default(autoincrement())
  empleadoId             BigInt   @map("empleado_id")
  sueldoBasicoAnterior   Decimal? @map("sueldo_basico_anterior") @db.Decimal(10, 2)
  sueldoBasicoNuevo      Decimal? @map("sueldo_basico_nuevo") @db.Decimal(10, 2)
  tarifaHorariaAnterior  Decimal? @map("tarifa_horaria_anterior") @db.Decimal(10, 2)
  tarifaHorariaNueva     Decimal? @map("tarifa_horaria_nueva") @db.Decimal(10, 2)
  fechaCambio            DateTime @map("fecha_cambio")
  cambioPorId            BigInt?  @map("cambio_por_id")
  razonCambio            String?  @map("razon_cambio") @db.VarChar(200)

  empleado Empleado @relation(fields: [empleadoId], references: [id])

  @@index([empleadoId, fechaCambio])
  @@map("historial_estructura_salarial")
}

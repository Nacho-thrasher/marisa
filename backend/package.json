{
  "name": "marisa-backend",
  "version": "0.1.1",
  "description": "API REST - Sistema de Gestión de Producción y Nómina",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json && tsc -p tsconfig.seed.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:reset": "tsx prisma/seed.prod.ts",
    "seed:reset:prod": "node dist/prisma/seed.prod.js",
    "reset:datos": "tsx prisma/reset-datos.ts",
    "reset:datos:prod": "node dist/prisma/reset-datos.js",
    "seed:productos": "tsx prisma/seed-productos.ts",
    "seed:productos:prod": "node dist/prisma/seed-productos.js",
    "seed:vendedores": "tsx prisma/seed-vendedores.ts",
    "seed:vendedores:prod": "node dist/prisma/seed-vendedores.js",
    "seed:insumos": "tsx prisma/seed-insumos.ts",
    "seed:insumos:prod": "node dist/prisma/seed-insumos.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.19.1",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}
